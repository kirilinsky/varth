{
  "name": "varth",
  "version": "1.0.0",
  "description": "Generate CSS theme variables from a configuration object.",
  "keywords": [
    "css",
    "themes",
    "css-variables",
    "design-tokens",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/varth.git"
  },
  "author": "Kirilinsky (https://github.com/kirilinsky)",
  "bugs": {
    "url": "https://github.com/kirilinsky/varth/issues"
  },
  "homepage": "https://github.com/kirilinsky/varth#readme"
}